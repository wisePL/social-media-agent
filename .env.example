# ============================================================
# Verse Eight Marketing Agent — 환경 변수 설정
# 이 파일을 복사해서 .env 로 저장하고 값을 채워넣으세요.
# cp .env.example .env
# ============================================================

# ------ Twitter / X API (OAuth 1.0a) ------
# developer.x.com 에서 앱 생성 후 획득
# 필요 권한: tweet.read, tweet.write, users.read
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ------ Discord Webhook ------
# #major-announcement 채널 설정 → 연동 → 웹훅 → 새 웹훅 → URL 복사
DISCORD_WEBHOOK_ANNOUNCEMENTS=

# ------ OMC Slack 알림 (완료 알림용) ------
# 파이프라인 완료 시 팀 슬랙 채널로 알림
# 설정: api.slack.com/apps → Create App → Incoming Webhooks → Activate → Add New Webhook to Workspace
OMC_SLACK_WEBHOOK=

# ------ Notion (이미 MCP로 연결됨 - 별도 설정 불필요) ------
# NOTION_TOKEN=  ← MCP 설정에서 관리됨

# ------ 선택사항: 성과 분석 알림 채널 ------
OMC_NOTIFY_CHANNEL=slack    # discord | slack | telegram
